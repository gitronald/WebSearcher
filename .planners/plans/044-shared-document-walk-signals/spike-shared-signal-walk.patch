+class SignalIndex:
+    """One shared document walk backing every component's ``_ComponentSignals``.
+
+    A subtree is a contiguous slice of the document's pre-order element list:
+    ``elements[start : end + 1]`` with ``start`` the root's position and ``end``
+    its last descendant's (right-spine descent, cf. ``reorder_by_dom_position``).
+    Slicing one materialized list per component replaces the per-component
+    ``cmpt.css('*')`` walks -- the same elements in the same order, so the
+    signal sets are identical by construction (plan 044).
+
+    The walk must be **post-extraction**: extraction restructures the tree
+    (the RHS handler detaches its column), so the extractor's pre-extraction
+    position snapshot over-spans -- verified empirically by the corpus
+    equivalence probe. Lazy: the walk runs on the first ``signals_for`` call,
+    so a SERP whose components are all pre-typed never pays it; only the
+    positions of the known component roots and their subtree ends are
+    recorded (a handful per SERP), not a full document position map. The
+    index is consumed during classification, before any parser mutates the
+    tree (``general`` top-menus and ``ai_overview`` buttons decompose nodes
+    -- see ``parse_serp``'s split classify/parse loops). A root missing from
+    the walk (e.g. a re-parsed fragment) falls back to its own subtree walk.
+    """
+
+    __slots__ = ("_elements", "_positions", "_roots", "_soup")
+
+    def __init__(self, soup: Node, roots: Iterable[Node]) -> None:
+        self._soup = soup
+        self._roots = roots
+        self._elements: list[Node] | None = None
+        self._positions: dict[int, int] = {}
+
+    def signals_for(self, cmpt: Node) -> _ComponentSignals:
+        if self._elements is None:
+            needed = set()
+            for root in self._roots:
+                needed.add(root.mem_id)
+                needed.add(last_descendant(root).mem_id)
+            self._elements = self._soup.css("*")
+            self._positions = {
+                m: i for i, el in enumerate(self._elements) if (m := el.mem_id) in needed
+            }
+        start = self._positions.get(cmpt.mem_id)
+        if start is None:
+            return _ComponentSignals(cmpt.css("*"))
+        end = self._positions.get(last_descendant(cmpt).mem_id, start)
+        return _ComponentSignals(self._elements[start : end + 1])
+
+
 _HEADER_CSS_BY_LEVEL: dict[int, tuple[str, ...]] = {
     level: (
         f'h{level}[role="heading"]',
